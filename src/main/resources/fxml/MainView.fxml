<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.carthagearena.controller.MainController"
            styleClass="root-pane">

    <!-- ─── Sidebar ─────────────────────────────────────────────────── -->
    <left>
        <VBox styleClass="sidebar" spacing="8" prefWidth="200">
            <padding><Insets top="24" right="16" bottom="24" left="16"/></padding>

            <!-- Logo -->
            <VBox alignment="CENTER" spacing="4">
                <Label text="🏟️" styleClass="logo-icon"/>
                <Label text="Carthage Arena" styleClass="logo-text"/>
                <Label text="Gestion Merchandising" styleClass="logo-subtitle"/>
            </VBox>

            <Separator styleClass="sidebar-divider"/>

            <!-- Navigation Client -->
            <Label text="BOUTIQUE" styleClass="sidebar-section-title"/>
            <Button fx:id="btnShop" text="🛒  E-Boutique"
                    styleClass="nav-btn"
                    onAction="#showShop"
                    maxWidth="Infinity"/>

            <Region prefHeight="20"/>

            <!-- Navigation Admin -->
            <Label text="ADMINISTRATION" styleClass="sidebar-section-title"/>
            <Button fx:id="btnMerch" text="🛍️  Produits"
                    styleClass="nav-btn"
                    onAction="#showMerch"
                    maxWidth="Infinity"/>
            <Button fx:id="btnOrders" text="📦  Commandes"
                    styleClass="nav-btn"
                    onAction="#showOrders"
                    maxWidth="Infinity"/>
            <Button fx:id="btnAi" text="🤖  IA Description"
                    styleClass="nav-btn"
                    onAction="#showAi"
                    maxWidth="Infinity"/>
            <Button fx:id="btnStats" text="📊  Dashboard"
                    styleClass="nav-btn"
                    onAction="#showStats"
                    maxWidth="Infinity"/>

            <Region VBox.vgrow="ALWAYS"/>
            
            <Button fx:id="btnPayment" text="💳  Stripe Portal"
                    styleClass="nav-btn-alt"
                    onAction="#showPayment"
                    maxWidth="Infinity"/>

            <Button fx:id="btnLogin" text="🔑  Se Connecter"
                    styleClass="nav-btn"
                    onAction="#showLogin"
                    maxWidth="Infinity"/>

            <Label fx:id="lblUser" text="Utilisateur" 
                   styleClass="sidebar-section-title" 
                   visible="false" managed="false"/>

            <Button fx:id="btnLogout" text="🚪  Déconnexion"
                    styleClass="nav-btn"
                    onAction="#onLogout"
                    maxWidth="Infinity"
                    visible="false" managed="false"/>

            <Separator styleClass="sidebar-divider"/>
            <Label text="Carthage Arena v1.1" styleClass="version-label"/>
        </VBox>
    </left>

    <!-- ─── Contenu principal ──────────────────────────────────────── -->
    <center>
        <StackPane fx:id="contentArea" styleClass="content-area">
        </StackPane>
    </center>

</BorderPane>
