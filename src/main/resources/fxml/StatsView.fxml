<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.carthagearena.controller.StatsController"
      styleClass="page-container" spacing="20">

    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

    <!-- En-tête -->
    <VBox spacing="4">
        <Label text="📊 Statistiques &amp; Dashboard" styleClass="page-title"/>
        <Label text="Aperçu global de l'activité commerciale" styleClass="page-subtitle"/>
    </VBox>

    <!-- KPIs -->
    <HBox spacing="16">
        <VBox styleClass="stat-card" style="-fx-border-color: #2ea043;" HBox.hgrow="ALWAYS">
            <Label text="💰 Chiffre d'Affaires" style="-fx-text-fill: #8b949e;"/>
            <Label fx:id="lblTotalRevenue" text="0.00 DT" styleClass="page-title" style="-fx-text-fill: #3fb950;"/>
        </VBox>
        <VBox styleClass="stat-card" style="-fx-border-color: #e6a817;" HBox.hgrow="ALWAYS">
            <Label text="📦 Commandes Totales" style="-fx-text-fill: #8b949e;"/>
            <Label fx:id="lblTotalOrders" text="0" styleClass="page-title" style="-fx-text-fill: #e6a817;"/>
        </VBox>
        <VBox styleClass="stat-card" style="-fx-border-color: #388bfd;" HBox.hgrow="ALWAYS">
            <Label text="🛍️ Total Produits" style="-fx-text-fill: #8b949e;"/>
            <Label fx:id="lblTotalProducts" text="0" styleClass="page-title" style="-fx-text-fill: #388bfd;"/>
        </VBox>
    </HBox>

    <!-- Graphiques Activité -->
    <HBox spacing="16" VBox.vgrow="ALWAYS">
        <!-- Stock des Top produits -->
        <VBox styleClass="main-table" HBox.hgrow="ALWAYS" prefWidth="400">
            <Label text="📦 Niveau de Stock (Top 5)" style="-fx-padding: 10; -fx-text-fill: #c9d1d9;"/>
            <BarChart fx:id="barChartSales" legendVisible="false" VBox.vgrow="ALWAYS">
                <xAxis><CategoryAxis label="Produit"/></xAxis>
                <yAxis><NumberAxis label="Quantité"/></yAxis>
            </BarChart>
        </VBox>

        <!-- Répartition par Type -->
        <VBox styleClass="main-table" HBox.hgrow="ALWAYS" prefWidth="400">
            <Label text="🏷️ Répartition par Type" style="-fx-padding: 10; -fx-text-fill: #c9d1d9;"/>
            <PieChart fx:id="pieChartTypes" VBox.vgrow="ALWAYS" legendSide="RIGHT"/>
        </VBox>
    </HBox>

    <!-- Graphiques Démographiques (Pro Dashboard) -->
    <HBox spacing="16" VBox.vgrow="ALWAYS">
        <!-- Répartition par Genre -->
        <VBox styleClass="main-table" HBox.hgrow="ALWAYS" prefWidth="350">
            <Label text="👥 Répartition par Genre" style="-fx-padding: 10; -fx-text-fill: #c9d1d9;"/>
            <PieChart fx:id="pieChartGender" VBox.vgrow="ALWAYS" legendSide="BOTTOM"/>
        </VBox>

        <!-- Répartition par Tranche d'Âge -->
        <VBox styleClass="main-table" HBox.hgrow="ALWAYS" prefWidth="350">
            <Label text="🎂 Tranches d'Âge" style="-fx-padding: 10; -fx-text-fill: #c9d1d9;"/>
            <BarChart fx:id="barChartAge" legendVisible="false" VBox.vgrow="ALWAYS">
                <xAxis>
                    <CategoryAxis label="Groupe"/>
                </xAxis>
                <yAxis>
                    <NumberAxis label="Utilisateurs"/>
                </yAxis>
            </BarChart>
        </VBox>
    </HBox>
</VBox>
