<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.carthagearena.controller.OrderController"
      styleClass="page-container" spacing="16">

    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

    <!-- ─── En-tête ──────────────────────────────────────────────────── -->
    <HBox alignment="CENTER_LEFT" spacing="16">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="📦 Gestion des Commandes" styleClass="page-title"/>
            <Label text="Suivi et gestion du cycle de vie des commandes" styleClass="page-subtitle"/>
        </VBox>
        <Button text="🔄 Actualiser" styleClass="btn, btn-secondary" onAction="#onRefresh"/>
    </HBox>

    <!-- ─── Stats ────────────────────────────────────────────────────── -->
    <HBox spacing="16">
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label text="📋" styleClass="stat-icon"/>
            <Label fx:id="lblTotalOrders" text="Total : 0" styleClass="stat-value"/>
        </VBox>
        <VBox styleClass="stat-card, stat-card-success" HBox.hgrow="ALWAYS">
            <Label text="💰" styleClass="stat-icon"/>
            <Label fx:id="lblTotalRevenue" text="Revenus : 0.00 DT" styleClass="stat-value"/>
        </VBox>
        <VBox styleClass="stat-card, stat-card-warning" HBox.hgrow="ALWAYS">
            <Label text="⏳" styleClass="stat-icon"/>
            <Label fx:id="lblPendingOrders" text="En attente : 0" styleClass="stat-value"/>
        </VBox>
    </HBox>

    <!-- ─── Filtre statut ────────────────────────────────────────────── -->
    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Filtrer par statut :"/>
        <ComboBox fx:id="cbStatusFilter" prefWidth="180"/>
    </HBox>

    <!-- ─── Tableau commandes ─────────────────────────────────────────── -->
    <SplitPane orientation="VERTICAL" VBox.vgrow="ALWAYS" dividerPositions="0.6">

        <TableView fx:id="tableOrders" styleClass="main-table">
            <columns>
                <TableColumn fx:id="colOrderId"      text="N° Commande" prefWidth="120"/>
                <TableColumn fx:id="colOrderDate"    text="Date"         prefWidth="160"/>
                <TableColumn fx:id="colOrderUser"    text="Client"       prefWidth="180"/>
                <TableColumn fx:id="colOrderTotal"   text="Total"        prefWidth="120"/>
                <TableColumn fx:id="colOrderStatus"  text="Statut"       prefWidth="120"/>
                <TableColumn fx:id="colOrderActions" text="Actions"      prefWidth="200"/>
            </columns>
            <placeholder>
                <Label text="Aucune commande trouvée" styleClass="empty-placeholder"/>
            </placeholder>
        </TableView>

        <!-- ─── Détail items ──────────────────────────────────────────── -->
        <VBox spacing="8" styleClass="detail-panel">
            <Label text="📋 Détail de la commande sélectionnée" styleClass="section-title"/>
            <TableView fx:id="tableItems" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colItemName"     text="Produit"      prefWidth="250"/>
                    <TableColumn fx:id="colItemQty"      text="Quantité"     prefWidth="100"/>
                    <TableColumn fx:id="colItemUnit"     text="Prix unitaire" prefWidth="130"/>
                    <TableColumn fx:id="colItemSubtotal" text="Sous-total"   prefWidth="130"/>
                </columns>
                <placeholder>
                    <Label text="Sélectionner une commande pour voir le détail"
                           styleClass="empty-placeholder"/>
                </placeholder>
            </TableView>
        </VBox>
    </SplitPane>

</VBox>
