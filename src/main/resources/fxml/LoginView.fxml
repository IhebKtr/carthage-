<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.carthagearena.controller.LoginController"
           style="-fx-background-color: #0B0E14;">

    <HBox alignment="CENTER" spacing="80" style="-fx-background-color: #0B0E14;">
        <padding><Insets top="20" right="60" bottom="20" left="60"/></padding>

        <!-- Left: Branding -->
        <VBox alignment="CENTER" HBox.hgrow="ALWAYS" spacing="12">
            <TextFlow style="-fx-font-size: 52px; -fx-font-weight: bold; -fx-font-style: italic;">
                <Text text="CARTHAGE " fill="WHITE"/>
                <Text text="ARENA" fill="#E50914"/>
            </TextFlow>
            <Label text="Esports Management System" styleClass="sub-header"
                   style="-fx-font-size: 18px;"/>
        </VBox>

        <!-- Right: Login Glass Panel -->
        <VBox alignment="CENTER_LEFT" spacing="24" styleClass="glass-panel"
              minWidth="400" maxWidth="400" minHeight="520">
            <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

            <!-- Title -->
            <VBox spacing="6">
                <Label text="🏟️" style="-fx-font-size: 36px;"/>
                <Label text="Connexion" styleClass="header-title"/>
                <Label text="Accédez à votre espace Carthage Arena" styleClass="sub-header"/>
            </VBox>

            <!-- Fields -->
            <VBox spacing="28" style="-fx-padding: 10 0 0 0;">
                <VBox spacing="6">
                    <Label text="Email" styleClass="input-label"/>
                    <TextField fx:id="tfUsername" promptText="votre@email.tn"
                               styleClass="rounded-input"/>
                </VBox>
                <VBox spacing="6">
                    <Label text="Mot de passe" styleClass="input-label"/>
                    <PasswordField fx:id="pfPassword" promptText="••••••••"
                                  styleClass="rounded-input" onAction="#onLogin"/>
                </VBox>
            </VBox>

            <!-- Error -->
            <Label fx:id="lblError" styleClass="feedback-error"
                   visible="false" wrapText="true" maxWidth="320"/>

            <!-- Buttons -->
            <VBox alignment="CENTER" spacing="12" style="-fx-padding: 6 0 0 0;">
                <Button text="SE CONNECTER" onAction="#onLogin"
                        styleClass="button-solid-red, button-full" prefWidth="320"/>
                <Button text="← Retour à la boutique" onAction="#onBackToShop"
                        style="-fx-background-color: transparent; -fx-text-fill: #9CA3AF; -fx-cursor: hand; -fx-font-size: 12px;"/>
            </VBox>
        </VBox>
    </HBox>

</StackPane>
