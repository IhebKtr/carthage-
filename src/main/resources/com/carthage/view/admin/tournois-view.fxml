<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox stylesheets="@../../css/main.css" spacing="20" style="-fx-background-color: -carthage-base; -fx-padding: 30;" xmlns="http://javafx.com/javafx/16" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.carthage.controllers.admin.TournoiManagementController">
    
    <!-- Top Header Bar -->
    <HBox alignment="CENTER_LEFT" spacing="20">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Gestion des Tournois" styleClass="header-title" />
            <Label text="Créer et gérer les tournois de la plateforme" styleClass="sub-header" />
        </VBox>
        <Button text="+ Créer" styleClass="button-solid-red" onAction="#handleCreate" />
    </HBox>

    <!-- Filters Bar -->
    <HBox spacing="15" alignment="CENTER_LEFT" styleClass="glass-panel" style="-fx-padding: 10;">
        <TextField fx:id="searchField" promptText="🔍 Rechercher un tournoi..." styleClass="rounded-input" HBox.hgrow="ALWAYS" />
        <ComboBox fx:id="gameFilter" promptText="Tous les jeux" styleClass="filter-toggle" prefWidth="160" />
        <ComboBox fx:id="statusFilter" promptText="Tous les statuts" styleClass="filter-toggle" prefWidth="160" />
    </HBox>

    <!-- List Header -->
    <HBox spacing="10" alignment="CENTER_LEFT" styleClass="glass-panel" style="-fx-padding: 10 20; -fx-background-radius: 8 8 0 0; -fx-border-color: #2A3441; -fx-border-width: 0 0 1 0;">
        <Label text="ID" prefWidth="80" style="-fx-text-fill: #9CA3AF; -fx-font-size: 11px; -fx-font-weight: bold;" />
        <Label text="NOM" prefWidth="180" style="-fx-text-fill: #9CA3AF; -fx-font-size: 11px; -fx-font-weight: bold;" />
        <Label text="JEU" prefWidth="120" style="-fx-text-fill: #9CA3AF; -fx-font-size: 11px; -fx-font-weight: bold;" />
        <Label text="ÉQUIPES" prefWidth="120" style="-fx-text-fill: #9CA3AF; -fx-font-size: 11px; -fx-font-weight: bold;" />
        <Label text="STATUT" prefWidth="100" style="-fx-text-fill: #9CA3AF; -fx-font-size: 11px; -fx-font-weight: bold;" />
        <Label text="CAGNOTTE" prefWidth="100" style="-fx-text-fill: #9CA3AF; -fx-font-size: 11px; -fx-font-weight: bold;" />
        <Label text="DATE" prefWidth="120" style="-fx-text-fill: #9CA3AF; -fx-font-size: 11px; -fx-font-weight: bold;" />
        <Label text="ACTIONS" prefWidth="120" style="-fx-text-fill: #9CA3AF; -fx-font-size: 11px; -fx-font-weight: bold; -fx-alignment: center;" />
    </HBox>

    <!-- Custom List -->
    <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" styleClass="edge-to-edge">
        <VBox fx:id="tournoisListContainer" spacing="0" styleClass="glass-panel" style="-fx-background-radius: 0 0 8 8;" />
    </ScrollPane>

</VBox>
