<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.carthage.controllers.admin.SkinManagementController"
      spacing="20" style="-fx-background-color: transparent;">

    <!-- Top Area: Title & Add Button -->
    <HBox alignment="CENTER_LEFT" spacing="20">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Gestion de la Boutique" styleClass="header-title"/>
            <Label text="Gérez les skins, leurs prix et la disponibilité." styleClass="sub-header"/>
        </VBox>
        <Button text="+ Ajouter un Skin" styleClass="button-primary" onAction="#onAddSkin"/>
    </HBox>

    <!-- Controls Area: Search & Filters -->
    <HBox spacing="15" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="🔍 Rechercher un skin..." 
                   styleClass="rounded-input" prefWidth="250"/>
        
        <Region HBox.hgrow="ALWAYS"/>
        
        <Label text="Filtrer:" style="-fx-text-fill: #9CA3AF;"/>
        <ComboBox fx:id="gameFilterCombo" promptText="Tous les Jeux" styleClass="filter-toggle" style="-fx-background-radius: 8px;"/>
        <ComboBox fx:id="rarityFilterCombo" promptText="Toutes Raretés" styleClass="filter-toggle" style="-fx-background-radius: 8px;"/>
    </HBox>

    <!-- Table Area -->
    <VBox VBox.vgrow="ALWAYS" styleClass="glass-panel" style="-fx-padding: 0;">
        <TableView fx:id="skinTable" VBox.vgrow="ALWAYS" styleClass="admin-table">
            <columns>
                <TableColumn fx:id="colImage" text="IMAGE" prefWidth="80" style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="colName" text="NOM" prefWidth="200"/>
                <TableColumn fx:id="colGame" text="JEU" prefWidth="120"/>
                <TableColumn fx:id="colPrice" text="PRIX (PC)" prefWidth="100"/>
                <TableColumn fx:id="colRarity" text="RARETÉ" prefWidth="100"/>
                <TableColumn fx:id="colActions" text="ACTIONS" prefWidth="120" style="-fx-alignment: CENTER;"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
    </VBox>
</VBox>
