<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.Insets?>

<VBox stylesheets="@../../css/main.css" spacing="20" style="-fx-background-color: -carthage-base; -fx-padding: 20;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.carthage.controllers.admin.ReclamationManagementController">
    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="20">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Gestion des Réclamations" styleClass="header-title" />
            <Label text="Gérez les tickets de support et les signalements des utilisateurs" styleClass="sub-header" />
        </VBox>
        <HBox spacing="15">
            <VBox alignment="CENTER" styleClass="stat-box-mini">
                <Label text="TOTAL" styleClass="stat-label-mini"/>
                <Label fx:id="totalLabel" text="-" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;" />
            </VBox>
            <VBox alignment="CENTER" styleClass="stat-box-mini">
                <Label text="EN ATTENTE" styleClass="stat-label-mini"/>
                <Label fx:id="pendingLabel" text="-" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #3B82F6;" />
            </VBox>
            <VBox alignment="CENTER" styleClass="stat-box-mini">
                <Label text="URGENT" styleClass="stat-label-mini"/>
                <Label fx:id="urgentLabel" text="-" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -carthage-accent;" />
            </VBox>
        </HBox>
    </HBox>

    <!-- Charts Section -->
    <HBox spacing="20" prefHeight="250">
        <VBox styleClass="glass-panel" HBox.hgrow="ALWAYS" alignment="CENTER">
            <PieChart fx:id="statusPieChart" title="Statuts" legendSide="BOTTOM" />
        </VBox>
        <VBox styleClass="glass-panel" HBox.hgrow="ALWAYS" alignment="CENTER">
            <BarChart fx:id="categoryBarChart" title="Catégories">
                <xAxis> <CategoryAxis /> </xAxis>
                <yAxis> <NumberAxis /> </yAxis>
            </BarChart>
        </VBox>
    </HBox>

    <VBox styleClass="glass-panel" prefHeight="200">
        <LineChart fx:id="activityLineChart" title="Évolution des Réclamations (14 jours)">
            <xAxis> <CategoryAxis /> </xAxis>
            <yAxis> <NumberAxis /> </yAxis>
        </LineChart>
    </VBox>

    <!-- Filters -->
    <HBox spacing="15">
        <Button text="Tout voir" styleClass="filter-toggle-active" />
        <Button text="En Attente" styleClass="filter-toggle" />
        <Button text="En Cours" styleClass="filter-toggle" />
        <Button text="Résolu" styleClass="filter-toggle" />
        <Button text="Urgent" styleClass="filter-toggle" />
    </HBox>

    <!-- Table -->
    <TableView fx:id="reclamationTable" VBox.vgrow="ALWAYS" styleClass="admin-table">
        <columns>
            <TableColumn fx:id="colSujet" text="SUJET / AUTEUR" prefWidth="250"/>
            <TableColumn fx:id="colCategorie" text="CATÉGORIE" prefWidth="150" />
            <TableColumn fx:id="colPriorite" text="PRIORITÉ" prefWidth="120" />
            <TableColumn fx:id="colStatut" text="STATUT" prefWidth="120" />
            <TableColumn fx:id="colDate" text="DATE" prefWidth="150" />
            <TableColumn fx:id="colActions" text="ACTIONS" prefWidth="120"/>
        </columns>
    </TableView>

</VBox>
