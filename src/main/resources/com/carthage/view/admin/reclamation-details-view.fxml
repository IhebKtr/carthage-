<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>

<VBox stylesheets="@../../css/main.css" spacing="20" style="-fx-background-color: -carthage-base; -fx-padding: 30;" xmlns="http://javafx.com/javafx/16" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.carthage.controllers.admin.ReclamationDetailsController">
    <!-- Top Header Bar -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Button text="←" styleClass="btn-icon-action" onAction="#handleBack" />
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label fx:id="subjectLabel" text="Reclamation Subject" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;" />
            <Label fx:id="authorLabel" text="By user@example.com • 2026-04-14" styleClass="sub-header" />
        </VBox>
        <HBox spacing="10" alignment="CENTER_RIGHT">
             <Label text="Statut:" styleClass="sub-header" />
             <ComboBox fx:id="statusCombo" styleClass="rounded-input" prefWidth="150" />
        </HBox>
    </HBox>

    <HBox spacing="30" VBox.vgrow="ALWAYS">
        <!-- Left Pane: Message & Responses -->
        <VBox spacing="15" HBox.hgrow="ALWAYS">
            <ScrollPane fx:id="scrollPane" VBox.vgrow="ALWAYS" fitToWidth="true" styleClass="transparent-scroll">
                <VBox fx:id="conversationBox" spacing="20" style="-fx-padding: 10;">
                    <!-- Original Message Box -->
                    <VBox spacing="10" style="-fx-background-color: #1A212D; -fx-padding: 20; -fx-background-radius: 12; -fx-border-color: #2A3441; -fx-border-radius: 12;">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label fx:id="originalAuthorLabel" text="Author Name" style="-fx-font-weight: bold; -fx-text-fill: -carthage-accent;" />
                            <Label fx:id="originalDateLabel" text="2026-04-14 10:00" styleClass="stat-label-mini" />
                        </HBox>
                        <Label fx:id="messageText" text="Message content here..." wrapText="true" style="-fx-text-fill: white; -fx-font-size: 14px;" />
                    </VBox>
                    
                    <!-- Dynamic responses will be injected here -->
                </VBox>
            </ScrollPane>

            <!-- Reply Box (hidden when RESOLVED) -->
            <VBox fx:id="replyBox" spacing="12" style="-fx-background-color: #0D1520; -fx-padding: 20; -fx-background-radius: 12; -fx-border-color: #3B82F6; -fx-border-radius: 12; -fx-border-width: 1.5;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="💬" style="-fx-font-size: 16px;" />
                    <Label text="Répondre au ticket" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #60A5FA;" />
                    <Region HBox.hgrow="ALWAYS" />
                    <HBox spacing="8" alignment="CENTER">
                        <Button text="👍" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-font-size: 16px;" onAction="#handleEmojiClick" />
                        <Button text="❤️" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-font-size: 16px;" onAction="#handleEmojiClick" />
                        <Button text="😂" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-font-size: 16px;" onAction="#handleEmojiClick" />
                        <Button text="😡" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-font-size: 16px;" onAction="#handleEmojiClick" />
                        <Button text="🙏" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-font-size: 16px;" onAction="#handleEmojiClick" />
                    </HBox>
                    <Button fx:id="micBtn" text="🎤 Dictée" 
                            style="-fx-background-color: transparent; -fx-text-fill: #9CA3AF; -fx-border-color: #4B5563; -fx-border-radius: 12; -fx-cursor: hand;" 
                            onAction="#handleToggleDictation" />
                </HBox>
                <TextArea fx:id="replyArea" promptText="Tapez votre réponse ici..." prefHeight="110" wrapText="true"
                          style="-fx-background-color: #111827; -fx-control-inner-background: #111827; -fx-text-fill: white; -fx-prompt-text-fill: #4B5563;
                                 -fx-background-radius: 8; -fx-border-color: #2563EB; -fx-border-radius: 8;
                                 -fx-border-width: 1; -fx-font-size: 13px; -fx-padding: 10;" />
                <HBox alignment="CENTER_RIGHT" spacing="12">
                    <Button text="Annuler" styleClass="btn-outline" onAction="#handleBack" />
                    <Button fx:id="markResolvedBtn" text="✅  Marquer comme Résolu"
                            style="-fx-background-color: rgba(74,222,128,0.15); -fx-text-fill: #4ADE80;
                                   -fx-border-color: #4ADE80; -fx-border-radius: 20; -fx-border-width: 1;
                                   -fx-background-radius: 20; -fx-font-weight: bold; -fx-padding: 8 18; -fx-cursor: hand;"
                            onAction="#handleMarkResolved" />
                    <Button text="📤  Envoyer la réponse" styleClass="button-solid-red" onAction="#handleSendReply" />
                </HBox>
            </VBox>

            <!-- Resolved Banner (shown when ticket is RESOLVED or CLOSED) -->
            <VBox fx:id="resolvedBanner" spacing="8" alignment="CENTER" managed="false" visible="false"
                  style="-fx-background-color: rgba(74,222,128,0.08); -fx-padding: 24;
                         -fx-background-radius: 12; -fx-border-color: rgba(74,222,128,0.4);
                         -fx-border-radius: 12; -fx-border-width: 1.5;">
                <Label text="✅  Ticket Résolu" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #4ADE80;" />
                <Label text="Ce ticket a été marqué comme résolu. Aucune réponse supplémentaire n'est nécessaire."
                       wrapText="true" style="-fx-text-fill: #9CA3AF; -fx-font-size: 12px;" />
                <Button text="↩  Réouvrir le ticket"
                        style="-fx-background-color: transparent; -fx-text-fill: #9CA3AF;
                               -fx-border-color: #4B5563; -fx-border-radius: 20; -fx-border-width: 1;
                               -fx-background-radius: 20; -fx-padding: 6 16; -fx-cursor: hand;"
                        onAction="#handleReopenTicket" />
            </VBox>
        </VBox>

        <!-- Right Pane: Metadata & Actions -->
        <VBox spacing="20" prefWidth="300">
            <!-- Ticket Info -->
            <VBox spacing="15" style="-fx-background-color: #141A23; -fx-padding: 20; -fx-background-radius: 12; -fx-border-color: #2A3441; -fx-border-radius: 12;">
                <Label text="DÉTAILS DU TICKET" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #9CA3AF;" />
                
                <VBox spacing="2">
                    <Label text="CATÉGORIE" styleClass="stat-label-mini" />
                    <Label fx:id="categoryLabel" text="Technique" style="-fx-text-fill: white; -fx-font-weight: bold;" />
                </VBox>
                
                <VBox spacing="2">
                    <Label text="PRIORITÉ" styleClass="stat-label-mini" />
                    <Label fx:id="priorityLabel" text="Haute" style="-fx-text-fill: #FBBF24; -fx-font-weight: bold;" />
                </VBox>

                <VBox spacing="2">
                    <Label text="DATE DE CRÉATION" styleClass="stat-label-mini" />
                    <Label fx:id="dateLabel" text="14/04/2026" style="-fx-text-fill: white; -fx-font-weight: bold;" />
                </VBox>
            </VBox>

            <!-- Danger Zone -->
            <VBox spacing="15" style="-fx-background-color: rgba(229, 9, 20, 0.05); -fx-padding: 20; -fx-background-radius: 12; -fx-border-color: rgba(229, 9, 20, 0.2); -fx-border-radius: 12;">
                <Label text="ZONE DE DANGER" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #FF4D4D;" />
                <Label text="La suppression du ticket est irréversible." wrapText="true" style="-fx-text-fill: #9CA3AF; -fx-font-size: 11px;" />
                <Button text="Supprimer le ticket" style="-fx-background-color: #FF4D4D; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 8 20;" onAction="#handleDelete" />
            </VBox>
        </VBox>
    </HBox>
</VBox>
