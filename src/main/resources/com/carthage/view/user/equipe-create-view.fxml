<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      alignment="TOP_CENTER" spacing="25" style="-fx-background-color: transparent;">

    <padding><Insets top="10" bottom="30" left="50" right="50"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <Button text="← Retour" onAction="#showEmptyState" 
                style="-fx-background-color: transparent; -fx-text-fill: -carthage-text-muted; -fx-cursor: hand;"/>
    </HBox>

    <VBox spacing="30" styleClass="glass-panel" maxWidth="600">
        <padding><Insets top="30" right="40" bottom="30" left="40"/></padding>

        <VBox spacing="8">
            <Label text="Créer votre Équipe" styleClass="header-title" style="-fx-font-size: 24px;"/>
            <Label text="Configurez l'identité de votre équipe." styleClass="text-muted"/>
        </VBox>

        <!-- Logo Upload Placeholder -->
        <VBox spacing="10">
            <Label text="Logo de l'équipe" styleClass="input-label"/>
            <HBox spacing="20" alignment="CENTER_LEFT">
                <StackPane style="-fx-background-color: #0B0E14; -fx-background-radius: 50; -fx-min-width: 80; -fx-min-height: 80; -fx-border-color: #2A3441; -fx-border-radius: 50; -fx-border-style: dashed;">
                    <Label text="📤" style="-fx-font-size: 20px;"/>
                </StackPane>
                <VBox spacing="5">
                    <Button text="Télécharger une image" styleClass="filter-toggle" style="-fx-background-radius: 20;"/>
                    <Label text="JPG ou PNG, max 2MB." styleClass="text-muted" style="-fx-font-size: 11px;"/>
                </VBox>
            </HBox>
        </VBox>

        <!-- Form Fields -->
        <VBox spacing="20">
            <VBox spacing="8">
                <HBox spacing="5" alignment="CENTER_LEFT">
                    <Label text="Nom de l'équipe" styleClass="input-label"/>
                    <Label text="*" style="-fx-text-fill: -carthage-accent;"/>
                </HBox>
                <TextField fx:id="createTeamName" promptText="Ex: Carthage Eagles" styleClass="rounded-input" maxWidth="Infinity"/>
            </VBox>

            <VBox spacing="8">
                <HBox spacing="5" alignment="CENTER_LEFT">
                    <Label text="Tag (Abbréviation)" styleClass="input-label"/>
                    <Label text="*" style="-fx-text-fill: -carthage-accent;"/>
                </HBox>
                <TextField fx:id="createTeamTag" promptText="EX: EGLS" styleClass="rounded-input" maxWidth="Infinity"/>
                <Label text="3 à 5 caractères qui apparaîtront à côté de vos pseudos." styleClass="text-muted" style="-fx-font-size: 11px;"/>
            </VBox>

            <VBox spacing="8">
                <Label text="Description" styleClass="input-label"/>
                <TextArea fx:id="createTeamDesc" promptText="Décrivez votre équipe, vos objectifs..." styleClass="rounded-input" prefHeight="100" wrapText="true"/>
            </VBox>
        </VBox>

        <!-- Checklist -->
        <VBox spacing="10" style="-fx-background-color: rgba(30,38,51,0.4); -fx-background-radius: 12; -fx-padding: 20; -fx-border-color: #1E2633; -fx-border-radius: 12;">
            <Label text="Conditions de Création" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;"/>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="✅" style="-fx-text-fill: #4ADE80;"/>
                <Label text="Vous deviendrez automatiquement le Leader." styleClass="text-muted" style="-fx-font-size: 12px;"/>
            </HBox>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="✅" style="-fx-text-fill: #4ADE80;"/>
                <Label text="Vous pourrez inviter jusqu'à 7 autres joueurs." styleClass="text-muted" style="-fx-font-size: 12px;"/>
            </HBox>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="✅" style="-fx-text-fill: #4ADE80;"/>
                <Label text="Seul le Leader peut inscrire l'équipe aux tournois." styleClass="text-muted" style="-fx-font-size: 12px;"/>
            </HBox>
        </VBox>

        <Button text="⊕  Créer l'Équipe" maxWidth="Infinity" styleClass="button-solid-red" 
                style="-fx-padding: 14 0; -fx-font-size: 15px; -fx-background-radius: 30;" 
                onAction="#onCreateTeamSubmit"/>
    </VBox>

</VBox>
