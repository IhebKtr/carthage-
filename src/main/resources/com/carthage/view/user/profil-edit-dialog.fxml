<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox stylesheets="@../../css/main.css" spacing="18"
      style="-fx-background-color: #141A23; -fx-padding: 28; -fx-border-color: #2A3441; -fx-border-radius: 12; -fx-background-radius: 12; -fx-border-width: 1;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.carthage.controllers.user.ProfilEditController">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT">
        <Label text="Modifier le Profil" styleClass="header-title" style="-fx-font-size: 20px;" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="✕" style="-fx-background-color: transparent; -fx-text-fill: #9CA3AF; -fx-font-size: 18px; -fx-cursor: hand;" onAction="#handleCancel"/>
    </HBox>

    <!-- Identity fields -->
    <VBox spacing="12">
        <VBox spacing="5">
            <Label text="Pseudo" styleClass="form-label" />
            <TextField fx:id="usernameField" styleClass="rounded-input" />
        </VBox>

        <VBox spacing="5">
            <Label text="Nickname (optionnel)" styleClass="form-label" />
            <TextField fx:id="nicknameField" styleClass="rounded-input" />
        </VBox>

        <VBox spacing="5">
            <Label text="Email" styleClass="form-label" />
            <TextField fx:id="emailField" styleClass="rounded-input" />
        </VBox>
    </VBox>

    <!-- Password change section -->
    <VBox spacing="10" style="-fx-padding: 8 0 0 0; -fx-border-color: transparent transparent #2A3441 transparent; -fx-border-width: 0 0 1 0;" />
    <VBox spacing="12">
        <Label text="Changer le mot de passe (optionnel)"
               style="-fx-text-fill: #9CA3AF; -fx-font-size: 12px; -fx-font-weight: bold;" />

        <VBox spacing="5">
            <Label text="Mot de passe actuel" styleClass="form-label" />
            <PasswordField fx:id="currentPasswordField" styleClass="rounded-input" />
        </VBox>

        <HBox spacing="12">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Nouveau mot de passe" styleClass="form-label" />
                <PasswordField fx:id="newPasswordField" styleClass="rounded-input" />
            </VBox>
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Confirmer" styleClass="form-label" />
                <PasswordField fx:id="confirmPasswordField" styleClass="rounded-input" />
            </VBox>
        </HBox>
    </VBox>

    <!-- Inline error/success area -->
    <Label fx:id="messageLabel" text="" wrapText="true"
           style="-fx-text-fill: #F87171; -fx-font-size: 12px;" />

    <!-- 2FA Section -->
    <VBox spacing="10" style="-fx-padding: 8 0 0 0; -fx-border-color: transparent transparent #2A3441 transparent; -fx-border-width: 0 0 1 0;" />
    <VBox spacing="12">
        <Label text="Authentification à deux facteurs (2FA)" style="-fx-text-fill: #9CA3AF; -fx-font-size: 12px; -fx-font-weight: bold;" />
        <Button fx:id="enable2FaButton" text="Activer 2FA" styleClass="btn-outline" onAction="#handleEnable2FA" />
        <VBox fx:id="twoFaBox" spacing="10" managed="false" visible="false">
            <ImageView fx:id="qrCodeImageView" fitWidth="150" fitHeight="150" preserveRatio="true"/>
            <HBox spacing="10">
                <TextField fx:id="twoFaCodeField" promptText="Code à 6 chiffres" styleClass="rounded-input" HBox.hgrow="ALWAYS"/>
                <Button text="Valider" styleClass="button-solid-red" onAction="#handleVerify2FA"/>
            </HBox>
        </VBox>
    </VBox>

    <Region VBox.vgrow="ALWAYS" />

    <!-- Actions -->
    <HBox alignment="CENTER_RIGHT" spacing="12" style="-fx-padding: 12 0 0 0;">
        <Button text="Annuler" styleClass="btn-outline" onAction="#handleCancel" />
        <Button text="Enregistrer" styleClass="button-solid-red" onAction="#handleSave" />
    </HBox>

</VBox>
