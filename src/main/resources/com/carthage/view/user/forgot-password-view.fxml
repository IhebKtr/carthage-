<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<StackPane stylesheets="@../../css/main.css"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.carthage.controllers.user.ForgotPasswordController">

    <HBox alignment="CENTER" spacing="50" style="-fx-background-color: -carthage-base;">

        <!-- Left Side: Branding -->
        <VBox alignment="CENTER" HBox.hgrow="ALWAYS" spacing="10">
            <Label text="CARTHAGE" styleClass="header-title"
                   style="-fx-font-size: 48px; -fx-text-fill: -carthage-accent;" />
            <Label text="Mot de passe oublié ?" styleClass="sub-header"
                   style="-fx-font-size: 18px;" />
        </VBox>

        <!-- Right Side: Form (Glassmorphism) -->
        <VBox alignment="CENTER_LEFT" spacing="20" styleClass="glass-panel"
              maxWidth="400" minWidth="400" minHeight="500">
            <padding>
                <Insets top="40" right="40" bottom="40" left="40"/>
            </padding>

            <Label text="Pas d'inquiétude," styleClass="header-title" />
            <Label text="Entrez votre email et nous vous enverrons un code à 6 chiffres pour réinitialiser votre mot de passe."
                   styleClass="sub-header" wrapText="true" />

            <VBox spacing="30" style="-fx-padding: 30 0 0 0;">
                <TextField fx:id="emailField" promptText="Email Address" />
            </VBox>

            <!-- Feedback labels -->
            <Label fx:id="errorLabel" wrapText="true" maxWidth="320" styleClass="feedback-error" />
            <Label fx:id="successLabel" wrapText="true" maxWidth="320"
                   style="-fx-text-fill: #4ade80; -fx-font-size: 12px;" />

            <VBox alignment="CENTER" spacing="10" style="-fx-padding: 10 0 0 0;">
                <Button fx:id="sendButton" text="Envoyer le code"
                        onAction="#onSendCodeClicked"
                        styleClass="button-primary" prefWidth="200" />
                <HBox alignment="CENTER" spacing="5">
                    <Label text="Vous vous en souvenez ?" styleClass="text-muted" />
                    <Button text="Se connecter" onAction="#onBackToLogin"
                            style="-fx-background-color: transparent; -fx-text-fill: -carthage-accent; -fx-cursor: hand; -fx-padding: 0;" />
                </HBox>
            </VBox>
        </VBox>

        <padding>
            <Insets top="20" right="50" bottom="20" left="50"/>
        </padding>
    </HBox>

</StackPane>