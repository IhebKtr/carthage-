<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/16" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.carthage.controllers.user.TournoisController"
      spacing="20" style="-fx-background-color: transparent;">

    <!-- Header -->
    <VBox spacing="4">
        <Label text="Mes Tournois" styleClass="header-title"/>
        <Label text="Gérez vos inscriptions et découvrez de nouveaux tournois." styleClass="sub-header"/>
    </VBox>

    <!-- Toolbar -->
    <HBox spacing="12" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="🔍  Rechercher un tournoi..."
                   style="-fx-background-color: #141A23; -fx-text-fill: white; -fx-prompt-text-fill: #6b7280;
                          -fx-background-radius: 20px; -fx-padding: 10 16 10 16; -fx-font-size: 13px;"
                   prefWidth="220"/>

        <ToggleButton fx:id="btnAll" text="Tous les Tournois" styleClass="filter-toggle-active"
                      onAction="#onFilterAll"/>
        <ToggleButton fx:id="btnMine" text="Mes Inscriptions" styleClass="filter-toggle"
                      onAction="#onFilterMine"/>
        <ToggleButton fx:id="btnDone" text="Terminés" styleClass="filter-toggle"
                      onAction="#onFilterDone"/>

        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnGridMode" text="⊞  Grille" styleClass="button-solid-red" style="-fx-background-radius: 20px; -fx-padding: 8 16;" onAction="#onModeGrid"/>
        <Button fx:id="btnCalendarMode" text="📅  Calendrier" styleClass="filter-toggle" style="-fx-background-radius: 20px; -fx-padding: 8 16;" onAction="#onModeCalendar"/>
    </HBox>

    <!-- Content Stack -->
    <StackPane VBox.vgrow="ALWAYS">
        <!-- Tournament Grid -->
        <AnchorPane fx:id="gridPaneView">
            <ScrollPane fitToWidth="true" fitToHeight="true"
                        AnchorPane.topAnchor="0.0"
                        AnchorPane.bottomAnchor="0.0"
                        AnchorPane.leftAnchor="0.0"
                        AnchorPane.rightAnchor="0.0"
                        styleClass="transparent-scroll">
                <content>
                    <FlowPane fx:id="tournoisGrid"
                              hgap="20" vgap="20"
                              prefWrapLength="9999"/>
                </content>
            </ScrollPane>
        </AnchorPane>

        <!-- Smart Calendar View -->
        <VBox fx:id="calendarPaneView" visible="false" spacing="15" style="-fx-background-color: #141A23; -fx-background-radius: 12; -fx-padding: 20;">
            <!-- Calendar Header -->
            <HBox alignment="CENTER" spacing="20">
                <Button text="◀" styleClass="btn-icon-action" onAction="#onPrevMonth"/>
                <Label fx:id="monthYearLabel" text="Avril 2026" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white; -fx-min-width: 150px; -fx-alignment: center;" />
                <Button text="▶" styleClass="btn-icon-action" onAction="#onNextMonth"/>
            </HBox>
            
            <!-- Week Days -->
            <GridPane fx:id="calendarGrid" hgap="1" vgap="1" VBox.vgrow="ALWAYS" style="-fx-background-color: #2A3441;">
                <columnConstraints>
                    <ColumnConstraints percentWidth="14.28" />
                    <ColumnConstraints percentWidth="14.28" />
                    <ColumnConstraints percentWidth="14.28" />
                    <ColumnConstraints percentWidth="14.28" />
                    <ColumnConstraints percentWidth="14.28" />
                    <ColumnConstraints percentWidth="14.28" />
                    <ColumnConstraints percentWidth="14.28" />
                </columnConstraints>
                <!-- Days will be dynamically generated -->
            </GridPane>
        </VBox>
    </StackPane>

</VBox>
