<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.carthage.controllers.user.TournoisController"
      spacing="20" style="-fx-background-color: transparent;">

    <!-- Header -->
    <VBox spacing="4">
        <Label text="Mes Tournois" styleClass="header-title"/>
        <Label text="Gérez vos inscriptions et découvrez de nouveaux tournois." styleClass="sub-header"/>
    </VBox>

    <!-- Toolbar -->
    <HBox spacing="12" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="🔍  Rechercher un tournoi..."
                   style="-fx-background-color: #141A23; -fx-text-fill: white; -fx-prompt-text-fill: #6b7280;
                          -fx-background-radius: 20px; -fx-padding: 10 16 10 16; -fx-font-size: 13px;"
                   prefWidth="220"/>

        <ToggleButton fx:id="btnAll" text="Tous les Tournois" styleClass="filter-toggle-active"
                      onAction="#onFilterAll"/>
        <ToggleButton fx:id="btnMine" text="Mes Inscriptions" styleClass="filter-toggle"
                      onAction="#onFilterMine"/>
        <ToggleButton fx:id="btnDone" text="Terminés" styleClass="filter-toggle"
                      onAction="#onFilterDone"/>

        <Region HBox.hgrow="ALWAYS"/>
        <Button text="⊞  Grille" styleClass="button-solid-red" style="-fx-background-radius: 20px; -fx-padding: 8 16;"/>
        <Button text="📅  Calendrier" styleClass="filter-toggle" style="-fx-background-radius: 20px; -fx-padding: 8 16;"/>
    </HBox>

    <!-- Tournament Grid -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
        <FlowPane fx:id="tournoisGrid" hgap="20" vgap="20" prefWrapLength="9999"
                  style="-fx-background-color: transparent; -fx-padding: 5 0 0 0;"/>
    </ScrollPane>

</VBox>
