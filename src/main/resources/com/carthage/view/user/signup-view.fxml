<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<StackPane stylesheets="@../../css/main.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.carthage.controllers.user.SignupController">

    <!-- Overall container: centered panel like the image -->
    <VBox alignment="CENTER" style="-fx-background-color: -carthage-base;">
        
        <!-- Logo Header -->
        <HBox alignment="CENTER" spacing="5">
            <Label text="CARTHAGE " style="-fx-font-family: 'Segoe UI'; -fx-font-size: 24px; -fx-font-weight: bold; -fx-font-style: italic; -fx-text-fill: white;" />
            <Label text="ARENA" style="-fx-font-family: 'Segoe UI'; -fx-font-size: 24px; -fx-font-weight: bold; -fx-font-style: italic; -fx-text-fill: -carthage-accent;" />
        </HBox>

        <VBox alignment="TOP_CENTER" spacing="15" styleClass="glass-panel" maxWidth="450" minWidth="450">
            <padding>
                <Insets top="30" right="40" bottom="30" left="40"/>
            </padding>
            <VBox.margin>
                <Insets top="20" bottom="20"/>
            </VBox.margin>
            
            <Label text="Créer un compte" styleClass="header-title" style="-fx-font-size: 20px; -fx-padding: 0 0 10 0;"/>
            
            <!-- Type de compte -->
            <VBox spacing="5" alignment="CENTER_LEFT">
                <Label text="Type de compte" styleClass="input-label" />
                <HBox spacing="15" alignment="CENTER">
                    <fx:define>
                        <ToggleGroup fx:id="accountTypeGroup" />
                    </fx:define>
                    <ToggleButton fx:id="joueurToggle" text="🎮 Joueur" toggleGroup="$accountTypeGroup" styleClass="type-toggle" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                    <ToggleButton fx:id="arbitreToggle" text="⚖ Arbitre" toggleGroup="$accountTypeGroup" styleClass="type-toggle" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                </HBox>
            </VBox>

            <!-- Nom d'utilisateur -->
            <VBox spacing="5" alignment="CENTER_LEFT">
                <Label text="Nom d'utilisateur" styleClass="input-label" />
                <TextField fx:id="pseudoField" promptText="Pseudo" styleClass="rounded-input" />
            </VBox>

            <!-- Email -->
            <VBox spacing="5" alignment="CENTER_LEFT">
                <Label text="Email" styleClass="input-label" />
                <TextField fx:id="emailField" promptText="nom@exemple.com" styleClass="rounded-input" />
            </VBox>

            <!-- Numéro de licence (Hidden by default) -->
            <VBox fx:id="licenceContainer" spacing="5" alignment="CENTER_LEFT">
                <Label text="Numéro de licence" styleClass="input-label" />
                <TextField fx:id="licenceField" promptText="Ex: ARB-2026-001" styleClass="rounded-input" />
            </VBox>

            <!-- Mot de passe -->
            <VBox spacing="5" alignment="CENTER_LEFT">
                <Label text="Mot de passe" styleClass="input-label" />
                <PasswordField fx:id="passwordField" promptText="••••••••" styleClass="rounded-input" />
            </VBox>

            <!-- Confirmer le mot de passe -->
            <VBox spacing="5" alignment="CENTER_LEFT">
                <Label text="Confirmer le mot de passe" styleClass="input-label" />
                <PasswordField fx:id="confirmPasswordField" promptText="••••••••" styleClass="rounded-input" />
            </VBox>
            
            <!-- Feedback labels -->
            <Label fx:id="errorLabel" wrapText="true" maxWidth="370" styleClass="feedback-error" />
            <Label fx:id="successLabel" wrapText="true" maxWidth="370" styleClass="feedback-success" />

            <!-- Actions -->
            <VBox style="-fx-padding: 5 0 0 0;" spacing="15">
                <Button text="S'inscrire" onAction="#onSignUpClicked" styleClass="button-solid-red, button-full"/>
                
                <HBox alignment="CENTER" spacing="10">
                    <Separator HBox.hgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-color: #2A3441 transparent transparent transparent;"/>
                    <Label text="ou s'inscrire avec" style="-fx-text-fill: #6b7280; -fx-font-size: 12px;"/>
                    <Separator HBox.hgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-color: #2A3441 transparent transparent transparent;"/>
                </HBox>
                
                <Button text="Discord" onAction="#onDiscordSignUpClicked" styleClass="button-discord, button-full"/>
                
                <HBox alignment="CENTER" spacing="5" style="-fx-padding: 10 0 0 0;">
                    <Label text="Déjà un compte?" styleClass="input-label" />
                    <Button text="Se connecter" onAction="#onNavigateToSignIn" style="-fx-background-color: transparent; -fx-text-fill: -carthage-accent; -fx-cursor: hand; -fx-padding: 0; -fx-font-weight: bold;" />
                </HBox>
            </VBox>
        </VBox>
    </VBox>
</StackPane>
