<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<StackPane stylesheets="@../../css/main.css" xmlns="http://javafx.com/javafx/16" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.carthage.controllers.user.LoginController">

    <!-- Overall container -->
    <HBox alignment="CENTER" spacing="50" style="-fx-background-color: -carthage-base;">
        
        <!-- Left Side: Branding -->
        <VBox alignment="CENTER" HBox.hgrow="ALWAYS" spacing="10">
            <Label text="CARTHAGE" styleClass="header-title" style="-fx-font-size: 48px; -fx-text-fill: -carthage-accent;" />
            <Label text="Esports Management System" styleClass="sub-header" style="-fx-font-size: 18px;" />
        </VBox>

        <!-- Right Side: Login Panel (Glassmorphism) -->
        <VBox alignment="CENTER_LEFT" spacing="20" styleClass="glass-panel" maxWidth="400" minWidth="400" minHeight="500">
            <padding>
                <Insets top="40" right="40" bottom="40" left="40"/>
            </padding>
            
            <Label text="Welcome Back," styleClass="header-title"/>
            <Label text="Sign in to your account to continue" styleClass="sub-header" />

            <VBox spacing="30" style="-fx-padding: 30 0 0 0;">
                <TextField fx:id="emailField" promptText="Email Address" />
                <PasswordField fx:id="passwordField" promptText="Password" />
            </VBox>

            <!-- Error feedback -->
            <Label fx:id="errorLabel" wrapText="true" maxWidth="320" styleClass="feedback-error" />
            
            <VBox alignment="CENTER" spacing="10" style="-fx-padding: 10 0 0 0;">
                <Button text="Sign In" onAction="#onSignInClicked" styleClass="button-primary" prefWidth="180" />
                <HBox alignment="CENTER" spacing="5">
                    <Label text="Don't have an account?" styleClass="text-muted" />
                    <Button text="Sign Up" onAction="#onNavigateToSignUp" style="-fx-background-color: transparent; -fx-text-fill: -carthage-accent; -fx-cursor: hand; -fx-padding: 0;" />
                </HBox>
            </VBox>
        </VBox>
        
        <padding>
            <Insets top="20" right="50" bottom="20" left="50"/>
        </padding>
    </HBox>

</StackPane>
