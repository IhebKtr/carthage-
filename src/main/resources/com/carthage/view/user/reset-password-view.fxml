<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<StackPane stylesheets="@../../css/main.css"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.carthage.controllers.user.ResetPasswordController">

    <HBox alignment="CENTER" spacing="50" style="-fx-background-color: -carthage-base;">

        <!-- Left Side: Branding -->
        <VBox alignment="CENTER" HBox.hgrow="ALWAYS" spacing="10">
            <Label text="CARTHAGE" styleClass="header-title" style="-fx-font-size: 48px; -fx-text-fill: -carthage-accent;" />
            <Label text="Nouveau mot de passe" styleClass="sub-header" style="-fx-font-size: 18px;" />
        </VBox>

        <!-- Right Side: Form (Glassmorphism) -->
        <VBox alignment="CENTER_LEFT" spacing="15" styleClass="glass-panel" maxWidth="420" minWidth="420" minHeight="620">
            <padding>
                <Insets top="35" right="40" bottom="35" left="40"/>
            </padding>

            <Label text="Réinitialisation," styleClass="header-title" />
            <Label text="Saisissez le code reçu par email et choisissez un nouveau mot de passe." styleClass="sub-header" wrapText="true" />

            <VBox spacing="18" style="-fx-padding: 15 0 0 0;">
                <TextField fx:id="emailField" promptText="Email" />
                <TextField fx:id="codeField" promptText="Code à 6 chiffres" />
                <PasswordField fx:id="passwordField" promptText="Nouveau mot de passe (min. 6 caractères)" />
                <PasswordField fx:id="confirmPasswordField" promptText="Confirmer le mot de passe" />
            </VBox>

            <!-- Feedback labels -->
            <Label fx:id="errorLabel" wrapText="true" maxWidth="340" styleClass="feedback-error" />
            <Label fx:id="successLabel" wrapText="true" maxWidth="340" style="-fx-text-fill: #4ade80; -fx-font-size: 12px;" />

            <VBox alignment="CENTER" spacing="10" style="-fx-padding: 10 0 0 0;">
                <Button fx:id="resetButton" text="Réinitialiser" onAction="#onResetClicked" styleClass="button-primary" prefWidth="200" />
                <HBox alignment="CENTER" spacing="5">
                    <Label text="Changé d'avis ?" styleClass="text-muted" />
                    <Button text="Retour au login" onAction="#onBackToLogin" style="-fx-background-color: transparent; -fx-text-fill: -carthage-accent; -fx-cursor: hand; -fx-padding: 0;" />
                </HBox>
            </VBox>
        </VBox>

        <padding>
            <Insets top="20" right="50" bottom="20" left="50"/>
        </padding>
    </HBox>

</StackPane>